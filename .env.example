APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Laravel Boost (local / debug only; disabled in production by package defaults)
BOOST_ENABLED=true
BOOST_BROWSER_LOGS_WATCHER=true

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Kioku voice originals (private disk). Local default is fine for development.
# Production MUST set the Laravel Cloud Object Storage disk name:
#   KIOKU_AUDIO_DISK=kioku-audio
# Leaving this at local on Cloud uses ephemeral disk; files vanish after
# instance recycle and playback returns 404.
KIOKU_AUDIO_DISK=local
# Kioku transcription (docs/product/kioku-final-remaining-implementation.md Phase A).
# Default 'none' stores audio and leaves transcription pending. Set 'openai'
# (plus OPENAI_API_KEY) per environment to enable real transcription.
KIOKU_TRANSCRIPTION_PROVIDER=none
KIOKU_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe-2025-12-15
KIOKU_TRANSCRIPTION_LANGUAGE=ja
KIOKU_TRANSCRIPTION_TIMEOUT=120
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Kioku concierge letters (Phase B). Manual generation only; disabled by default.
KIOKU_CONCIERGE_ENABLED=false
KIOKU_CONCIERGE_DEFAULT_CHARACTER=shiori
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_VIDEOS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Inertia SSR (default true for local/production; PHPUnit sets false via phpunit.xml)
INERTIA_SSR_ENABLED=true
# INERTIA_SSR_URL=http://127.0.0.1:13714

# AI (Anthropic) — optional; without a key, Kioku save still works and enrichment fails safely
ANTHROPIC_API_KEY=
AI_MODEL_CHEAP=claude-haiku-4-5-20251001
AI_MODEL_STRONG=claude-sonnet-4-6
AI_MONTHLY_USD_PER_USER=10

# Google Calendar (Yoyu)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/yoyu/settings/calendar/callback"
GOOGLE_CALENDAR_SYNC_TTL_MINUTES=15
GOOGLE_CALENDAR_SYNC_PAST_DAYS=1
GOOGLE_CALENDAR_SYNC_FUTURE_DAYS=7
# 'mock' serves fixture events (local/testing only); 'auto' uses the real chain
YOYU_CALENDAR_DRIVER=auto
